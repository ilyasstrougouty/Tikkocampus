{
  "name": "tikkocampus",
  "version": "2.1.6",
  "description": "Premium Electron interface for Tikkocampus",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build": "npm run dist"
  },
  "build": {
    "appId": "com.tikkocampus.app",
    "productName": "Tikkocampus",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "publish": ["github"],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../dist/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "app_logo.ico"
    },
    "nsis": {
      "include": "installer.nsh",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Tikkocampus",
      "installerIcon": "app_logo.ico",
      "uninstallerIcon": "app_logo.ico",
      "uninstallDisplayName": "Tikkocampus",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education",
      "minimumSystemVersion": "11.0.0"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ilyasstrougouty/Tikkocampus.git"
  },
  "keywords": [],
  "author": "Tikkocampus Team",
  "license": "ISC",
  "devDependencies": {
    "electron": "^34.3.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
